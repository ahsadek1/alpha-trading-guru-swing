# ATG — Alpha Trading Guru — Environment Variables
# Set all of these in Railway → Variables

# Telegram
ATG_TELEGRAM_TOKEN=your_bot_token_here
ATG_TELEGRAM_CHAT_ID=8573754783

# Alpaca Paper Trading
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
PAPER_MODE=true

# Data APIs
POLYGON_API_KEY=your_polygon_key
ALPHA_VANTAGE_KEY=your_av_key
FRED_API_KEY=your_fred_key
ORATS_API_KEY=your_orats_key
DEEPSEEK_API_KEY=your_deepseek_key

# System
ATG_DB_PATH=./data/atg.db
INITIAL_CAPITAL=100000
MAX_POSITIONS=8
RISK_PER_TRADE_PCT=0.01
